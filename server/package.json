{
  "name": "globebotter-server",
  "version": "1.0.0",
  "description": "GlobeBotter API server",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "set NODE_ENV=development && nodemon index.js",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3",
    "openai": "^6.32.0",
    "pg": "^8.11.3",
    "serverless-http": "^4.0.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ]
  }
}
